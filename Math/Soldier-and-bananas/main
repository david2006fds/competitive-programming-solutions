#include <bits/stdc++.h>
#include <string>
#include <math.h>
#include <cstdlib>
using namespace std;
int main() {
    int precio;
    int dinero;
    int cantidad;
    int res;
    cin>>precio>>dinero>>cantidad;
        for(int i=1;i<cantidad+1;i++){
            res+=i*precio;
        }
        if(dinero>res){cout<<"0";}
        else{
            int resultado= abs(res-dinero);
            cout<<resultado;
        }
}
