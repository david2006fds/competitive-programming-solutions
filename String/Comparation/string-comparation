#include <bits/stdc++.h>
#include <string>
using namespace std;
int main(){
    string word1;
    getline(cin,word1);
    string word2;
    getline(cin,word2);
    cout<<compareStrings(word1,word2)<<endl;//res=0 si son iguales, res=1 si word1 es mayor y res=-1 si word1 es menor.
}

int compareStrings(string word1, string word2) {
    int size = word1.size();

    for (int i = 0; i < size; i++) {
        char c1 = tolower(word1[i]);
        char c2 = tolower(word2[i]);

        if (c1 < c2) return -1;
        if (c1 > c2) return 1;
    }

    return 0;
}
